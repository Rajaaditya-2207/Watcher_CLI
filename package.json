{
  "name": "@AdiRajaaditya/watcher-cli",
  "version": "0.1.0",
  "description": "A CLI-based development observer that translates code changes into human-readable narratives",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "watcher": "dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Rajaaditya-2207/Watcher_CLI.git"
  },
  "homepage": "https://Rajaaditya-2207.github.io/Watcher_CLI",
  "bugs": {
    "url": "https://github.com/Rajaaditya-2207/Watcher_CLI/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "cli",
    "documentation",
    "ai",
    "development",
    "productivity"
  ],
  "author": "Team KREONYX",
  "license": "MIT",
  "dependencies": {
    "blessed": "^0.1.81",
    "boxen": "^7.1.1",
    "chalk": "^5.3.0",
    "chokidar": "^3.5.3",
    "commander": "^11.1.0",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "inquirer": "^9.2.12",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "ora": "^8.0.1",
    "react": "^19.2.4",
    "sql.js": "^1.10.3"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.27",
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^29.5.11",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^20.10.6",
    "@types/react": "^19.2.14",
    "@types/sql.js": "^1.4.9",
    "esbuild": "^0.27.3",
    "eslint": "^8.56.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
